{
  // 前台 API Web Host 的基底設定檔。
  // 這個專案主要提供公開查詢型 API，因此整體設定與後台 API 類似，
  // 但在驗證與 Swagger 呈現上有不同策略。
  "ConnectionStrings": {
    // ABP 平台層資料庫連線字串。
    // 這裡對應 IFare_APIDbContext 會用到的預設資料庫。
    // 目前名稱寫成 IFare_FDAPIDb，與部分其他檔案中的 IFare_APIDb 命名不同，部署前建議再次確認。
    "Default": "Server=CHAINWIN-CHAINW\\SQLEXPRESS; Database=IFare_FDAPIDb; Trusted_Connection=True;",

    // 前後台共用的 IFare 業務資料庫。
    // 當程式建立 IFareContext 時，MyConnectionStringResolver 會把連線導向這個設定值。
    "IFare": "Server=CHAINWIN-CHAINW\\SQLEXPRESS; Database=IFare; Trusted_Connection=True;",

    // 本機開發用的 ABP 平台層資料庫連線字串。
    // Development 環境下會由 RolloutConfigurer 覆寫到 Default。
    "Local_Default": "Server=localhost; Database=IFare_FDAPIDb; Trusted_Connection=True;",

    // 本機開發用的 IFare 業務資料庫連線字串。
    // Development 環境下會由 RolloutConfigurer 覆寫到 IFare。
    "Local_IFare": "Server=localhost; Database=IFare; Trusted_Connection=True;"
  },
  "RolloutSetting": {
    // 部署版本標記。
    // 用途與後台 API 相同，會影響連線字串切換與 Swagger 標題顯示。
    "TargetVersion": "Local",
    "Swagger": {
      // Swagger 文件標題。
      // 啟動時會再由 RolloutConfigurer 補上最終版本標籤。
      "DocTitle": "【Local】IFare API"
    }
  },
  "App": {
    // 前台 API 對外根網址。
    // 一些框架服務、絕對路徑生成與外部整合會以它作為站點基準。
    "ServerRootAddress": "https://localhost:44311/",

    // 前台網站根網址。
    // 主要用於描述呼叫此 API 的前台站點位置。
    "ClientRootAddress": "http://localhost:4200/",

    // 前台 API 開放的 CORS 白名單。
    // 這些來源可以直接在瀏覽器端呼叫公開 API。
    "CorsOrigins": "http://localhost:4200,http://localhost:8080,http://localhost:8081,http://localhost:3000"
  },
  "Authentication": {
    "JwtBearer": {
      // 是否啟用 JWT Bearer 驗證。
      // 前台公開查詢 API 目前多半採匿名存取，因此此處設為 false。
      "IsEnabled": "false",

      // JWT 簽章金鑰。
      // 即使目前未啟用 Bearer 驗證，保留這組值仍可作為未來啟用授權時的基礎設定。
      "SecurityKey": "IFare_API_C353E59B083F4E93",

      // JWT 發行者名稱。
      "Issuer": "IFare_API",

      // JWT 受眾名稱。
      "Audience": "IFare_API"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        // Kestrel 監聽位址。
        // 節點名稱雖為 Http，但目前使用的是 https://localhost:44311/。
        "Url": "https://localhost:44311/"
      }
    }
  },
  "Swagger": {
    // 是否在 Swagger 畫面顯示 XML 摘要說明。
    // 前台 API 目前開啟摘要顯示，比較有利於公開查詢介面的閱讀。
    "ShowSummaries": true
  }
}
