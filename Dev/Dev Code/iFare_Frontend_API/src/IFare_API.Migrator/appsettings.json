{
  // 前台 API Migrator 專用設定檔。
  // 主要負責跑 IFare_APIDbContext 對應的 ABP 平台層 migration 與 seed。
  "ConnectionStrings": {
    // Migrator 預設使用的資料庫。
    // 這裡的資料庫名稱為 IFare_APIDb，和 Web Host 基底檔中的 IFare_FDAPIDb 命名不同，
    // 若實際環境只保留其中一個名稱，建議一併統一，以免 migration 與 API 連到不同資料庫。
    "Default": "Server=localhost; Database=IFare_APIDb; Trusted_Connection=True;"
  }
}
