{
  // 後台 API Web Host 的基底設定檔。
  // 這份檔案會先被載入，之後若目前環境有 appsettings.{Environment}.json，
  // 會再由對應環境檔覆蓋同名欄位。
  "ConnectionStrings": {
    // ABP 預設系統資料庫連線字串。
    // 這條主要提供 IFare_BDAPIDbContext 使用，保存 Tenant / Role / User / Setting 等平台層資料。
    "Default": "Server=CHAINWIN-CHAINW\\SQLEXPRESS; Database=IFare_BDAPIDb; Trusted_Connection=True;",

    // 業務資料庫連線字串。
    // 自訂的 MyConnectionStringResolver 會在偵測到 IFareContext 時改接這條，
    // 因此基金會實際內容資料、政策資料與前後台共用資料大多會從這裡讀寫。
    "IFare": "Server=CHAINWIN-CHAINW\\SQLEXPRESS; Database=IFare; Trusted_Connection=True;",

    // 本機開發用的 ABP 系統資料庫連線字串。
    // 當 RolloutConfigurer 判斷目前是 Development 環境時，
    // 會把 ConnectionStrings:Default 改寫成這個值。
    "Local_Default": "Server=localhost; Database=IFare_BDAPIDb; Trusted_Connection=True;",

    // 本機開發用的 IFare 業務資料庫連線字串。
    // 與 Local_Default 的概念相同，只是供 IFareContext 使用。
    "Local_IFare": "Server=localhost; Database=IFare; Trusted_Connection=True;"
  },
  "RolloutSetting": {
    // 部署目標版本標記。
    // RolloutConfigurer 會依環境決定是否保留 Local，或在非 Development 時轉為 Release。
    // 這個值除了影響連線字串切換，也會影響 Swagger 顯示名稱。
    "TargetVersion": "Local",
    "Swagger": {
      // Swagger 文件標題。
      // 啟動時會再透過 RolloutConfigurer 自動補齊版本標籤，讓畫面能看出目前是 Local / Release。
      "DocTitle": "【Local】IFare API"
    }
  },
  "App": {
    // 後台 API 對外根網址。
    // 常用於產生絕對網址、回應中的路徑基準，以及部分框架內部的站點資訊。
    "ServerRootAddress": "https://localhost:44311/",

    // 後台前端根網址。
    // 主要提供前後端整合設定使用，通常用來表示管理介面的入口位址。
    "ClientRootAddress": "http://localhost:4200/",

    // 允許跨來源呼叫 API 的白名單，使用逗號分隔。
    // Startup 會把這串文字拆開後餵給 CORS 設定，列出的網域才能直接從瀏覽器呼叫此 API。
    "CorsOrigins": "http://localhost:4200,http://localhost:8080,http://localhost:8081,http://localhost:3000,http://localhost:5173,https://112.121.114.177"
  },
  "Authentication": {
    "JwtBearer": {
      // 是否啟用 JWT Bearer 驗證。
      // 後台管理 API 需要登入與授權，所以這裡為 true。
      "IsEnabled": "true",

      // JWT 簽章金鑰。
      // TokenAuthController 與 JwtBearer 驗證都會依賴這個值驗證 Token 是否可信。
      "SecurityKey": "IFare_BDAPI_65E345CD2669463E",

      // JWT 發行者名稱。
      // 建立與驗證 Token 時必須一致，否則 Token 會被判定無效。
      "Issuer": "IFare_BDAPI",

      // JWT 受眾名稱。
      // 用來限制此 Token 是發給哪一類 API / Client 使用。
      "Audience": "IFare_BDAPI"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        // Kestrel 實際監聽的網址與埠號。
        // 雖然節點名稱叫 Http，但目前設定值是 https://localhost:44311/。
        "Url": "https://localhost:44311/"
      }
    }
  },
  "Swagger": {
    // 是否在 Swagger UI 中顯示 XML 註解摘要。
    // 後台 API 目前關閉摘要顯示，畫面會以較精簡的方式呈現。
    "ShowSummaries": false
  },

  // 自訂版本號。
  // Startup 會把它當作 Swagger 文件版本字串使用，例如 v1.0.0。
  "Ver": "1.0.0"
}
