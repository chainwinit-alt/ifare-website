{
  // 後台 API Migrator 專用設定檔。
  // 這個專案只負責跑 ABP 預設系統資料庫的 migration / seed，
  // 不會像 Web Host 一樣承接完整的 API、Swagger、JWT 或 Kestrel 設定。
  "ConnectionStrings": {
    // Migrator 執行時使用的主連線字串。
    // 這裡對應 IFare_BDAPIDb，也就是 ABP 平台層資料庫。
    // 若要改變 migration 目標資料庫，通常就是修改這一條。
    "Default": "Server=localhost; Database=IFare_BDAPIDb; Trusted_Connection=True;"
  }
}
