                    <mxGeometry x="1100" y="230" width="570" height="410" as="geometry"/>
                </mxCell>
                <mxCell id="backend" value="&lt;b&gt;iFare_Backend&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;後台管理系統&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font&gt;框架：Vue 3 + Vite&lt;br&gt;語言：TypeScript&lt;br&gt;UI：Element Plus&lt;br&gt;狀態：Pinia (持久化)&lt;br&gt;HTTP：Axios&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;verticalAlign=top;spacingTop=8;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="1120" y="250" width="240" height="155" as="geometry"/>
                </mxCell>
                <mxCell id="be-modules" value="&lt;b&gt;管理模組 (views/) — CRUD&lt;/b&gt;&lt;hr&gt;&lt;font&gt;最新消息 (News/)&lt;br&gt;福利文章 (Articles/Welfare/)&lt;br&gt;懶人包 (Articles/Lazy/)&lt;br&gt;福利政策 (IFare/Policy/)&lt;br&gt;常見問題 (IFare/QA/)&lt;br&gt;洽辦單位 (IFare/OfficeUnit/)&lt;br&gt;公益夥伴 (Collaborator/)&lt;br&gt;代碼維護 (Code/) ×6 種&lt;br&gt;帳號管理 / 個人設定 / 圖片管理&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#d6b656;fontSize=14;verticalAlign=top;spacingTop=5;" parent="1" vertex="1">
                    <mxGeometry x="1385" y="245" width="275" height="195" as="geometry"/>
                </mxCell>
                <mxCell id="be-features" value="&lt;b&gt;功能元件&lt;/b&gt;&lt;hr&gt;&lt;font&gt;CompHtmlEditor — TinyMCE 富文本&lt;br&gt;CardTable — 資料表格&lt;br&gt;CardSearchParam — 搜尋面板&lt;br&gt;AppAside — 側邊導覽 (依權限)&lt;br&gt;ApexCharts — 數據分析儀表板&lt;br&gt;DialogAlert / DialogErrorInfo&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#d6b656;fontSize=14;verticalAlign=top;spacingTop=5;" parent="1" vertex="1">
                    <mxGeometry x="1390" y="460" width="260" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="be-auth" value="&lt;b&gt;認證 &amp;amp; 權限&lt;/b&gt;&lt;hr&gt;&lt;font&gt;JWT Bearer Token 認證&lt;br&gt;Pinia 持久化 Token 儲存&lt;br&gt;Router Guard 路由守衛&lt;br&gt;&lt;br&gt;&lt;b&gt;三種角色：&lt;/b&gt;&lt;br&gt;🔴 管理者 — 全功能+帳號管理&lt;br&gt;🟡 編輯者 — 內容+代碼維護&lt;br&gt;🟢 檢視者 — 僅瀏覽(唯讀)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#d6b656;fontSize=14;verticalAlign=top;spacingTop=5;" parent="1" vertex="1">
