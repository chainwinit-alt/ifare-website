                <mxCell id="frontend" value="&lt;b&gt;iFare_Frontend&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666&quot;&gt;前台官方網站&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font&gt;框架：Nuxt 3 (SSR)&lt;br&gt;語言：TypeScript&lt;br&gt;樣式：SCSS + Normalize.css&lt;br&gt;HTTP：$fetch (Nuxt 內建)&lt;br&gt;模組：nuxt-gtag, nuxt-simple-sitemap&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;verticalAlign=top;spacingTop=8;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="120" y="245" width="240" height="360" as="geometry"/>
                </mxCell>
                <mxCell id="fe-pages" value="&lt;b&gt;頁面 (pages/)&lt;/b&gt;&lt;hr&gt;&lt;font&gt;首頁 (index.vue)&lt;br&gt;關於長穩 (about.vue)&lt;br&gt;最新消息 (news.vue)&lt;br&gt;福利專欄 (articles.vue)&lt;br&gt;懶人包 (articles/lazy.vue)&lt;br&gt;i-Fare 福利查詢 (ifare.vue)&lt;br&gt;查詢結果 / 福利詳情 / 洽辦單位&lt;br&gt;公益夥伴 (collaborator.vue)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#6c8ebf;fontSize=14;verticalAlign=top;spacingTop=5;" parent="1" vertex="1">
                    <mxGeometry x="400" y="320" width="210" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="fe-comp" value="&lt;b&gt;共用元件 (components/)&lt;/b&gt;&lt;hr&gt;&lt;font&gt;AppHeader.vue — 導覽列&lt;br&gt;AppFooter.vue — 頁尾&lt;br&gt;CompSelect.vue — 下拉選單&lt;br&gt;CompSelectElse.vue — 特殊篩選&lt;br&gt;CompSelectRecipient.vue — 受助對象&lt;br&gt;CompPage.vue — 分頁 (數字型)&lt;br&gt;CompPageNum.vue — 分頁 (簡潔型)&lt;br&gt;CompBreadCrumb.vue — 麵包屑 (空)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#6c8ebf;fontSize=14;verticalAlign=top;spacingTop=5;" parent="1" vertex="1">
                    <mxGeometry x="640" y="400" width="300" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="fe-style" value="&lt;b&gt;樣式系統 (assets/style/)&lt;/b&gt;&lt;hr&gt;&lt;font&gt;_color.scss — 色彩變數&lt;br&gt;_font.scss — 字型定義&lt;br&gt;_mixin.scss — 共用 mixin&lt;br&gt;_animation.scss — 動畫&lt;br&gt;rwd/ — 響應式斷點&lt;br&gt;components/ — 元件樣式&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#6c8ebf;fontSize=14;verticalAlign=top;spacingTop=5;" parent="1" vertex="1">
